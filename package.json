{
  "name": "x-platform",
  "version": "0.1.0",
  "private": true,
  "description": "X — Multi-sektör birleşik işletme platformu (damga + lokma + santral + ticaret modülleri)",
  "scripts": {
    "dev": "pnpm -r --parallel --filter ./apps/* dev",
    "dev:api": "pnpm --filter @x/api dev",
    "dev:web": "pnpm --filter @x/web dev",
    "build": "pnpm -r --filter ./apps/* build",
    "build:api": "pnpm --filter @x/api build",
    "build:web": "pnpm --filter @x/web build",
    "start:api": "pnpm --filter @x/api start",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @x/db generate",
    "db:migrate": "pnpm --filter @x/db migrate",
    "db:seed": "pnpm --filter @x/db seed",
    "format": "prettier -w \"**/*.{ts,tsx,json,md}\""
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
