# --- Core ---
NODE_ENV=development
PORT=4200
APP_URL=http://localhost:5200
API_URL=http://localhost:4200
PUBLIC_BASE_URL=https://x.deploi.net

# --- Database ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/x_platform
DATABASE_SCHEMA=public

# --- Supabase Auth ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- Session / Auth ---
SESSION_SECRET=change-me-min-32-chars-random
COOKIE_DOMAIN=.deploi.net

# --- Redis (optional, in-memory fallback) ---
REDIS_URL=

# --- Email / Resend ---
RESEND_API_KEY=
EMAIL_FROM=no-reply@deploi.net

# --- AI Providers (per-tenant override via integration_connections) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# --- Messaging (Turkish compliance) ---
KEP_USERNAME=
KEP_PASSWORD=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Iyzico (billing) ---
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# --- Encryption ---
INTEGRATION_ENCRYPTION_KEY=change-me-32-chars-minimum-secret

# --- Module flags (which modules are bundled) ---
ENABLED_MODULES=damga,lokma,santral,ticaret
